# Gemini API key for AI chat in Code Studio
# Get one from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Server port (default 3001)
# PORT=3001

# HiveMQ Cloud MQTT bridge (get from console.hivemq.cloud)
HIVEMQ_BROKER_URL=your-cluster.s1.eu.hivemq.cloud
HIVEMQ_USERNAME=your_hivemq_username
HIVEMQ_PASSWORD=your_hivemq_password
