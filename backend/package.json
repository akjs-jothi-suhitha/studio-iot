{
  "name": "smart-iot-backend",
  "version": "1.0.0",
  "description": "Smart IOT platform backend simulation and project storage service",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "postinstall": "prisma generate",
    "install:arduino-cli": "bash scripts/install-arduino-cli.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mqtt": "^5.15.1",
    "serialport": "^13.0.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/serialport": "^8.0.5",
    "@types/ws": "^8.5.10",
    "prisma": "^5.14.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  }
}
