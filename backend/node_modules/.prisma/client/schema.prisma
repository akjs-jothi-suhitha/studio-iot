datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "darwin", "windows"]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  name        String
  boardType   String // e.g. "arduino_uno", "esp32"
  circuitJson String // JSON stringified components and wires
  codeText    String // C++ code
  widgetsJson String // Blynk dashboard configurations
  apiKey      String   @unique @default(uuid()) // Dashboard API Key
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
